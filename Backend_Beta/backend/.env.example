APP_NAME=Overpass Recruiting API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=sqlite:///./overpass_recruiting.db
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
DEFAULT_TOP_K=10
TFIDF_MAX_FEATURES=5000
VECTORIZER_ARTIFACT_PATH=./artifacts/tfidf_vectorizer.joblib
USER_AGENT=OverpassRecruiting/0.1 (local-dev)
ADMIN_API_KEY=
OPENAI_API_KEY=
OPENAI_LABEL_MODEL=gpt-5.2
NAICS_VERSION=2022
INDUSTRY_ARTIFACT_DIR=./artifacts/industry
INDUSTRY_PROMPT_VERSION=naics_company_v1
INDUSTRY_TRAINING_MIN_CONFIDENCE=0.70
INDUSTRY_SEMANTIC_WEIGHT=0.80
INDUSTRY_ALIGNMENT_WEIGHT=0.20
